[global]
    monitor = 0
    follow = mouse
    width = 300
    origin = top-right
    offset = 10x50
    notification_limit = 5
    progress_bar = true
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 10
    frame_width = 2
    separator_color = frame
    font = JetBrains Mono 11
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    stack_duplicates = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 32
    corner_radius = 0
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cc99ff"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cc99ff"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
